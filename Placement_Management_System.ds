				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			interviewer
			(
    			type = text
				displayname = "Interviewer"
	 			row = 1
	 			column = 1   
				width = medium
			)
			interview_date
			(
    			type = date
				displayname = "Interview Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			interview_time
			(
    			type = time
				displayname = "Interview Time"
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			interview_type
			(
				type = picklist
				displayname = "Interview Type"
				values = {"Panel","Technical","Video","HR"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			feedback
			(
    			type = textarea
				displayname = "Feedback"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			result
			(
				type = picklist
				displayname = "Result"
				values = {"Pass","Reconsider","Not Selected","Fail"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Interview Scheduled","Interview In Progress","Interview Rescheduled","Interview Cancelled","Interview Completed","Feedback Reviewed","Result Decided","Interview Closed"}
			}
		}
