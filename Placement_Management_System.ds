	reports
	{
		list placements_Report
		{
			displayName = "All Placements"
			show all rows from placements    
			(
				student as "Student"
				job as "Job"
				company as "Company"
				offer_status as "Offer Status"
				offer_date as "Offer Date"
				start_date as "Start Date"
				offer_letter as "Offer Letter"
				status as "Status"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (offer_status == "Accepted")
				fields = [offer_status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (offer_status == "Pending")
				fields = [offer_status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (offer_status == "Rejected")
				fields = [offer_status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban placements_by_status
		{
			displayName = "Statuses"
			show all rows from placements    
			(
				student as "Student"
				job as "Job"
				company as "Company"
				offer_status as "Offer Status"
				offer_date as "Offer Date"
				start_date as "Start Date"
				offer_letter as "Offer Letter"
				status as "Status"
			)
			options
			(
	 			display field = status
	 		)
		}
		list interviews_Report
		{
			displayName = "All Interviews"
			show all rows from interviews    
			(
				student as "Student"
				job as "Job"
				company as "Company"
				interviewer as "Interviewer"
				interview_date as "Interview Date"
				interview_time as "Interview Time"
				interview_type as "Interview Type"
				feedback as "Feedback"
				result as "Result"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (interview_type == "HR")
				fields = [interview_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (interview_type == "Panel")
				fields = [interview_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (interview_type == "Technical")
				fields = [interview_type]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban interviews_by_interview_type
		{
			displayName = "Interview Types"
			show all rows from interviews    
			(
				student as "Student"
				job as "Job"
				company as "Company"
				interviewer as "Interviewer"
				interview_date as "Interview Date"
				interview_time as "Interview Time"
				interview_type as "Interview Type"
				feedback as "Feedback"
				result as "Result"
			)
			options
			(
	 			display field = interview_type
	 		)
		}
		list students_Report
		{
			displayName = "All Students"
			show all rows from students    
			(
				student_id as "Student ID"
				first_name1 as "First Name"
				last_name1 as "Last Name"
				email as "Email"
				phone as "Phone"
				dob as "Date of Birth"
				gender as "Gender"
				major as "Major"
				gpa as "GPA"
				graduation_year as "Graduation Year"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (gender == "Male")
				fields = [gender]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (gender == "Other")
				fields = [gender]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban students_by_gender
		{
			displayName = "Genders"
			show all rows from students    
			(
				student_id as "Student ID"
				first_name1 as "First Name"
				last_name1 as "Last Name"
				email as "Email"
				phone as "Phone"
				dob as "Date of Birth"
				gender as "Gender"
				major as "Major"
				gpa as "GPA"
				graduation_year as "Graduation Year"
			)
			options
			(
	 			display field = gender
	 		)
		}
		list companies_Report
		{
			displayName = "All Companies"
			show all rows from companies    
			(
				company_id as "Company ID"
				company_name as "Company Name"
				industry as "Industry"
				website as "Website"
				contact_person as "Contact Person"
				contact_email as "Contact Email"
				contact_phone as "Contact Phone"
				address  as "Address"
	 			(
	      			displayformat = [address_line_1+""+address_line_2+""+district_city+""+state_province+""+postal_Code+""+country]
	      			enable = Link_to_Map,Show_As_Text
	 			)
				founded_year as "Founded Year"
			)
		}
		list job_openings_Report
		{
			displayName = "All Job Openings"
			show all rows from job_openings    
			(
				job_id as "Job ID"
				title as "Title"
				company as "Company"
				department as "Department"
				location as "Location"
				job_type as "Job Type"
				salary_min as "Minimum Salary"
				(
					display = total,average,min,max	
				)
				salary_max as "Maximum Salary"
				(
					display = total,average,min,max	
				)
				posted_date as "Posted Date"
				status as "Status"
				description as "Description"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (job_type == "Contract")
				fields = [job_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (job_type == "Internship")
				fields = [job_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (job_type == "Part-Time")
				fields = [job_type]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban job_openings_by_job_type
		{
			displayName = "Job Types"
			show all rows from job_openings    
			(
				job_id as "Job ID"
				title as "Title"
				company as "Company"
				department as "Department"
				location as "Location"
				job_type as "Job Type"
				salary_min as "Minimum Salary"
				(
					display = total,average,min,max	
				)
				salary_max as "Maximum Salary"
				(
					display = total,average,min,max	
				)
				posted_date as "Posted Date"
				status as "Status"
				description as "Description"
			)
			options
			(
	 			display field = job_type
	 		)
		}
		list placement_analytics_Report
		{
			displayName = "All Placement Analytics"
			show all rows from placement_analytics    
			(
				total_students as "Total Students"
				placed_students as "Placed Students"
				placement_rate as "Placement Rate"
				(
					display = total,average,min,max	
				)
				avg_salary as "Average Salary"
				(
					display = total,average,min,max	
				)
				top_company as "Top Company"
				top_role as "Top Role"
				highest_package as "Highest Package"
				(
					display = total,average,min,max	
				)
				total_companies as "Total Companies"
			)
		}
	}
